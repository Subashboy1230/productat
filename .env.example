# ---- Database (serverless Postgres: Neon or Vercel Postgres) ----
# Pooled connection string used by the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Direct (non-pooled) connection used for migrations. On Neon use the
# "direct" connection string; on Vercel Postgres use POSTGRES_URL_NON_POOLING.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ---- Auth.js ----
# Generate one with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-byte-string"
# Optional in dev; set to your canonical URL in production.
# AUTH_URL="https://productat.com"

# ---- GitHub OAuth app ----
# Create at https://github.com/settings/developers (New OAuth App).
# Authorization callback URL: https://YOURDOMAIN/api/auth/callback/github
AUTH_GITHUB_ID="your-github-oauth-client-id"
AUTH_GITHUB_SECRET="your-github-oauth-client-secret"

# ---- Admin allowlist ----
# Comma-separated emails that get the ADMIN role on sign-in.
ADMIN_EMAILS="subashraj411@gmail.com"
